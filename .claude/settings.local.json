  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PR_NUM=$(jq -r '.tool_input.command' | grep -oE 'gh pr merge ([0-9]+)' | awk '{print $NF}'); if [ -z \"$PR_NUM\" ]; then exit 0; fi; TITLE=$(gh pr view \"$PR_NUM\" --json title -q .title 2>/dev/null); if ! echo \"$TITLE\" | grep -q '^chore(main): release'; then exit 0; fi; VERSION=$(echo \"$TITLE\" | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+'); CHANGELOG=$(gh api 'repos/roryford/BaseChatKit/contents/CHANGELOG.md?ref=release-please--branches--main' -H 'Accept: application/vnd.github.raw' 2>/dev/null); if echo \"$CHANGELOG\" | grep -A 20 \"^## \\[$VERSION\\]\" | grep -q '^\\*\\*'; then exit 0; fi; echo '{\"decision\":\"block\",\"reason\":\"RELEASE PR DETECTED: '\"$TITLE\"'. CHANGELOG not yet rewritten — the '\"$VERSION\"' entry still has auto-generated bullet points. Rewrite it with bold title prose on the release branch first, then retry.\"}';",
            "timeout": 15,
            "statusMessage": "Checking if this is a release PR..."
          }
        ]
      }
    ]
  }
